#--------------------------------------------------------------------
# Production Environment Configuration
# Copy this file to `.env` on the production server and replace the
# placeholder values before serving traffic.
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'https://api.example.com/'
app.forceGlobalSecureRequests = true
app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = 127.0.0.1
database.default.database = asetify_eci
database.default.username = asetify_user
database.default.password = change-me
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_general_ci
database.default.DBDebug = false

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

encryption.key = change-me-with-a-long-random-secret

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# Leave `session.savePath` unset to use the framework default:
# WRITEPATH . 'session'

#--------------------------------------------------------------------
# COOKIE
#--------------------------------------------------------------------

cookie.secure = true

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

logger.threshold = 4
